{
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "build": "remix build",
    "dev": "remix dev --no-restart -c \"npm run start\"",
    "start": "wrangler pages dev --compatibility-date=2023-06-21 ./public",
    "typecheck": "tsc",
    "db:migrate": "drizzle-kit generate:sqlite",
    "db:list-local": "wrangler d1 migrations list chore-db --local",
    "db:apply-local": "wrangler d1 migrations apply chore-db --local",
    "db:list": "wrangler d1 migrations list chore-db",
    "db:apply": "wrangler d1 migrations apply chore-db"
  },
